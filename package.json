{
  "name": "ffxiv",
  "version": "1.0.0",
  "description": "CSS compiler for the FFXIV system",
  "scripts": {
    "build": "sass src/scss/ffxiv.scss css/ffxiv.css --style=expanded --no-source-map",
    "watch": "sass src/scss/ffxiv.scss css/ffxiv.css --style=expanded --source-map --watch"
  },
  "browserslist": [
    "last 3 versions"
  ],
  "author": "",
  "license": "MIT",
  "private": true,
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "globals": "^17.6.0",
    "htmllint": "^0.8.0",
    "htmllint-cli": "^0.0.7",
    "sass": "^1.53.0"
  }
}
