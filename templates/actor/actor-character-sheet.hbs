<div class="{{cssClass}} {{actor.type}} flexcol">
  {{!-- Sheet Header --}}
  <header class="sheet-header">
    <div class="header-fields">
      <div class="charname">
        {{#if actorEditMode }}
          <h1>
            <input name="name"
                   type="text"
                   value="{{actor.name}}"
                   placeholder="{{localize 'FFXIV.Name'}}" />
          </h1>
        {{else}}
          <h1>{{actor.name}}</h1>
        {{/if}}
      </div>
      {{#if editable }}
      <button type="button"
              class="actor-edit-toggle {{#if actorEditMode }}active{{/if }}"
              aria-label="{{localize 'FFXIV.CharacterSheet.EditSheet' }}"
              aria-pressed="{{#if actorEditMode }}true{{else }}false{{/if }}"
              title="{{#if actorEditMode }}{{localize 'FFXIV.CharacterSheet.LockSheet' }}{{else }}{{localize 'FFXIV.CharacterSheet.EditSheet'}}{{/if}}">
        <i class="fa-solid {{#if actorEditMode }}fa-lock-open{{else }}fa-lock{{/if }}"></i>
      </button>
    {{/if}}
    <div class="header-info">
      {{#if system.class.customIcon }}
        <img class="class-icon" src="{{system.class.customIcon}}" alt="class icon" width="48" height="48">
      {{/if}}
      <div class="class-info">
        <div class="level">{{system.experience.level.value}}</div>
        <div class="class-name">
          {{#if (eq "custom" system.class.name) }}
            <span>{{ localize (labelize 'classes' system.class.name_custom)}}</span>
          {{else}}
            <span>{{ localize (labelize 'classes' system.class.name)}}</span>
          {{/if}}
          {{#if (not (eq system.activeTitle "")) }}
            <span>- {{system.activeTitle}}</span>{{/if}}
          </div>
        </div>
      </div>
    </div>
  </header>
  {{!-- Sheet Tab Navigation --}}
  {{> "systems/ffxiv/templates/actor/parts/tabs.hbs" displayLimited=true limited=limited
  items=(characterTabs settings)
  }}
  <div class="sheet-body-wrapper">
    <!-- The fixed part to the left -->
    {{> "systems/ffxiv/templates/actor/parts/actor-sidebar.hbs"}}
    {{!-- Sheet Body --}}
    <section class="sheet-body">
      {{!-- Fight Tab --}}
      <div class="tab abilities" data-group="primary" data-tab="abilities">
        {{> "systems/ffxiv/templates/actor/parts/actor-abilities.hbs" }}
      </div>
      {{!-- Biography Tab --}}
      <div class="tab attributes" data-group="primary" data-tab="attributes">
        {{> "systems/ffxiv/templates/actor/parts/actor-attributes.hbs" }}
      </div>
      {{!-- Biography Tab --}}
      <div class="tab profile" data-group="primary" data-tab="roleplay">
        {{> "systems/ffxiv/templates/actor/parts/actor-profile.hbs" }}
      </div>
      {{!-- Owned Items Tab --}}
      <div class="tab items" data-group="primary" data-tab="items">
        {{> "systems/ffxiv/templates/actor/parts/actor-items.hbs"}}
      </div>
      {{!-- Companions Tab --}}
      <div class="tab items" data-group="primary" data-tab="companions">
        {{> "systems/ffxiv/templates/actor/parts/actor-companions.hbs"}}
      </div>
      {{!-- Effects Tab --}}
      <div class="tab effects" data-group="primary" data-tab="effects">
        {{> "systems/ffxiv/templates/actor/parts/actor-effects.hbs"}}
      </div>
      {{!-- Configuration Tab --}}
      <div class="tab settings" data-group="primary" data-tab="settings">
        {{> "systems/ffxiv/templates/actor/parts/actor-settings.hbs"}}
      </div>
    </section>
  </div>
</div>
