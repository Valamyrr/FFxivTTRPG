<div class="actor-abilities modern-tab-layout">
  <div class="abilities-tab-content modern-panel">
    <!-- Sub-tab navigation for abilities -->
    <nav class="abilities-sub-tabs" data-group="abilities-sub-tabs">
      <a class="sub-tab {{#if (eq currentAbilityTab 'primary')}}active{{/if}}"
         data-tab="primary"
         title="{{localize 'FFXIV.Abilities.Primary'}}">
        {{localize 'FFXIV.Abilities.Primary'}}
        <div class="chip"></div>
      </a>
      <a class="sub-tab {{#if (eq currentAbilityTab 'secondary')}}active{{/if}}"
         data-tab="secondary"
         title="{{localize 'FFXIV.Abilities.Secondary'}}">
        {{localize 'FFXIV.Abilities.Secondary'}}
        <div class="chip"></div>
      </a>
      <a class="sub-tab {{#if (eq currentAbilityTab 'instant')}}active{{/if}}"
         data-tab="instant"
         title="{{localize 'FFXIV.Abilities.Instant'}}">
        {{localize 'FFXIV.Abilities.Instant'}}
        <div class="chip"></div>
      </a>
      <a class="sub-tab {{#if (eq currentAbilityTab 'traits')}}active{{/if}}"
         data-tab="traits"
         title="{{localize 'FFXIV.Abilities.Trait'}}">
        {{localize 'FFXIV.Abilities.Traits'}}
        <div class="chip"></div>
      </a>
    </nav>
    <!-- Sub-tab content -->
    {{#if (eq currentAbilityTab 'primary')}}
    <section class="sub-tab-content active" data-tab="primary">
      {{!-- Primary abilities content here --}}
      {{#each primary_abilities }}
        <div class="ability-container">
          {{> "systems/ffxiv/templates/actor/parts/actor-card-abilities.hbs" this}}
          <div class="move-buttons">
            {{#unless @first}}
            <button type="button"
                    class="move-up"
                    data-item-id="{{_id}}"
                    data-type="primary_ability">▲</button>
          {{/unless}}
          {{#unless @last}}
          <button type="button"
                  class="move-down"
                  data-item-id="{{_id}}"
                  data-type="primary_ability">▼</button>
        {{/unless}}
      </div>
    </div>
  {{/each}}
</section>
{{/if}}
{{#if (eq currentAbilityTab 'secondary')}}
<section class="sub-tab-content active" data-tab="secondary">
  {{!-- Secondary abilities content here --}}
  {{#each secondary_abilities }}
    <div class="ability-container">
      {{> "systems/ffxiv/templates/actor/parts/actor-card-abilities.hbs" this}}
      <div class="move-buttons">
        {{#unless @first}}
        <button type="button"
                class="move-up"
                data-item-id="{{_id}}"
                data-type="secondary_ability">▲</button>
      {{/unless}}
      {{#unless @last}}
      <button type="button"
              class="move-down"
              data-item-id="{{_id}}"
              data-type="secondary_ability">▼</button>
    {{/unless}}
  </div>
</div>
{{/each}}
</section>
{{/if}}
{{#if (eq currentAbilityTab 'instant')}}
<section class="sub-tab-content active" data-tab="instant">
  {{!-- Instant abilities content here --}}
  {{#each instant_abilities }}
    <div class="ability-container">
      {{> "systems/ffxiv/templates/actor/parts/actor-card-abilities.hbs" this}}
      <div class="move-buttons">
        {{#unless @first}}
        <button type="button"
                class="move-up"
                data-item-id="{{_id}}"
                data-type="instant_ability">▲</button>
      {{/unless}}
      {{#unless @last}}
      <button type="button"
              class="move-down"
              data-item-id="{{_id}}"
              data-type="instant_ability">▼</button>
    {{/unless}}
  </div>
</div>
{{/each}}
</section>
{{/if}}
{{#if (eq currentAbilityTab 'traits')}}
<section class="sub-tab-content active" data-tab="traits">
  {{#each (reverse limit_break) }}
    {{> "systems/ffxiv/templates/actor/parts/actor-card-limitbreak.hbs" this}}
  {{/each}}
  {{#each traits }}
    <div class="ability-container">
      {{> "systems/ffxiv/templates/actor/parts/actor-card-traits.hbs" this}}
      <div class="move-buttons">
        {{#unless @first}}
        <button type="button"
                class="move-up"
                data-item-id="{{_id}}"
                data-type="trait">▲</button>
      {{/unless}}
      {{#unless @last}}
      <button type="button"
              class="move-down"
              data-item-id="{{_id}}"
              data-type="trait">▼</button>
    {{/unless}}
  </div>
</div>
{{/each}}
</section>
{{/if}}
</div>
</div>
