<div class="actor-abilities actor-player-abilities modern-tab-layout">
  <div class="abilities-tab-content modern-panel">
    <nav class="abilities-sub-tabs ability-full-tabs" data-group="abilities-sub-tabs">
      <a class="sub-tab {{#if (eq currentAbilityTab 'primary')}}active{{/if}}"
         data-tab="primary">
        {{localize 'FFXIV.Tags.Primary'}}
        <i class="fa-solid fa-circle" aria-hidden="true"></i>
        <div class="chip"></div>
      </a>
      <a class="sub-tab {{#if (eq currentAbilityTab 'secondary')}}active{{/if}}"
         data-tab="secondary">
        {{localize 'FFXIV.Tags.Secondary'}}
        <i class="fa-solid fa-triangle" aria-hidden="true"></i>
        <div class="chip"></div>
      </a>
      <a class="sub-tab {{#if (eq currentAbilityTab 'instant')}}active{{/if}}"
         data-tab="instant">
        {{localize 'FFXIV.Tags.Instant'}}
        <i class="fa-solid fa-bolt" aria-hidden="true"></i>
        <div class="chip"></div>
      </a>
      <a class="sub-tab {{#if (eq currentAbilityTab 'traits')}}active{{/if}}"
         data-tab="traits">
        {{localize 'FFXIV.Abilities.Traits'}}
        <i class="fa-solid fa-scroll" aria-hidden="true"></i>
        <div class="chip"></div>
      </a>
    </nav>
    <nav class="abilities-sub-tabs ability-quick-tabs" data-group="abilities-sub-tabs">
      <a class="sub-tab {{#if (eq currentAbilityTab 'primary')}}active{{/if}}"
         data-tab="primary"
         aria-label="{{localize 'FFXIV.Tags.Primary'}}">
        <i class="fa-solid fa-circle" aria-hidden="true"></i>
      </a>
      <a class="sub-tab {{#if (eq currentAbilityTab 'secondary')}}active{{/if}}"
         data-tab="secondary"
         aria-label="{{localize 'FFXIV.Tags.Secondary'}}">
        <i class="fa-solid fa-triangle" aria-hidden="true"></i>
      </a>
      <a class="sub-tab {{#if (eq currentAbilityTab 'instant')}}active{{/if}}"
         data-tab="instant"
         aria-label="{{localize 'FFXIV.Tags.Instant'}}">
        <i class="fa-solid fa-bolt" aria-hidden="true"></i>
      </a>
      <a class="sub-tab {{#if (eq currentAbilityTab 'traits')}}active{{/if}}"
         data-tab="traits"
         aria-label="{{localize 'FFXIV.Abilities.Traits'}}">
        <i class="fa-solid fa-scroll" aria-hidden="true"></i>
      </a>
    </nav>
    {{#if (eq currentAbilityTab 'primary')}}
    <section class="sub-tab-content active" data-tab="primary">
      {{#each primary_abilities }}
        <div class="ability-container {{#if comboSource}}combo-source{{/if}} {{#if comboTarget}}combo-target{{/if}} {{#if comboBranch}}combo-branch{{/if}}">
          {{> "systems/ffxiv/templates/actor/parts/actor-card-abilities.hbs" this}}
          <div class="move-buttons">
            {{#unless @first}}
            <button type="button"
                    class="move-up"
                    data-item-id="{{_id}}"
                    data-type="primary_ability"
                    aria-label="{{localize 'FFXIV.MoveUp'}}">
              <i class="fa-solid fa-chevron-up" aria-hidden="true"></i>
            </button>
          {{/unless}}
          {{#unless @last}}
          <button type="button"
                  class="move-down"
                  data-item-id="{{_id}}"
                  data-type="primary_ability"
                  aria-label="{{localize 'FFXIV.MoveDown'}}">
            <i class="fa-solid fa-chevron-down" aria-hidden="true"></i>
          </button>
        {{/unless}}
      </div>
    </div>
  {{else}}
    <div class="abilities-empty-hint">{{ localize "FFXIV.Job.DropAbilities" }}</div>
  {{/each}}
</section>
{{/if}}
{{#if (eq currentAbilityTab 'secondary')}}
<section class="sub-tab-content active" data-tab="secondary">
  {{#each secondary_abilities }}
    <div class="ability-container {{#if comboSource}}combo-source{{/if}} {{#if comboTarget}}combo-target{{/if}} {{#if comboBranch}}combo-branch{{/if}}">
      {{> "systems/ffxiv/templates/actor/parts/actor-card-abilities.hbs" this}}
      <div class="move-buttons">
        {{#unless @first}}
        <button type="button"
                class="move-up"
                data-item-id="{{_id}}"
                data-type="secondary_ability"
                aria-label="{{localize 'FFXIV.MoveUp'}}">
          <i class="fa-solid fa-chevron-up" aria-hidden="true"></i>
        </button>
      {{/unless}}
      {{#unless @last}}
      <button type="button"
              class="move-down"
              data-item-id="{{_id}}"
              data-type="secondary_ability"
              aria-label="{{localize 'FFXIV.MoveDown'}}">
        <i class="fa-solid fa-chevron-down" aria-hidden="true"></i>
      </button>
    {{/unless}}
  </div>
</div>
{{else}}
  <div class="abilities-empty-hint">{{ localize "FFXIV.Job.DropAbilities" }}</div>
{{/each}}
</section>
{{/if}}
{{#if (eq currentAbilityTab 'instant')}}
<section class="sub-tab-content active" data-tab="instant">
  {{#each instant_abilities }}
    <div class="ability-container {{#if comboSource}}combo-source{{/if}} {{#if comboTarget}}combo-target{{/if}} {{#if comboBranch}}combo-branch{{/if}}">
      {{> "systems/ffxiv/templates/actor/parts/actor-card-abilities.hbs" this}}
      <div class="move-buttons">
        {{#unless @first}}
        <button type="button"
                class="move-up"
                data-item-id="{{_id}}"
                data-type="instant_ability"
                aria-label="{{localize 'FFXIV.MoveUp'}}">
          <i class="fa-solid fa-chevron-up" aria-hidden="true"></i>
        </button>
      {{/unless}}
      {{#unless @last}}
      <button type="button"
              class="move-down"
              data-item-id="{{_id}}"
              data-type="instant_ability"
              aria-label="{{localize 'FFXIV.MoveDown'}}">
        <i class="fa-solid fa-chevron-down" aria-hidden="true"></i>
      </button>
    {{/unless}}
  </div>
</div>
{{else}}
  <div class="abilities-empty-hint">{{ localize "FFXIV.Job.DropAbilities" }}</div>
{{/each}}
</section>
{{/if}}
{{#if (eq currentAbilityTab 'traits')}}
<section class="sub-tab-content active" data-tab="traits">
  {{#unless hasTraitAbilities}}
    <div class="abilities-empty-hint">{{ localize "FFXIV.Job.DropAbilities" }}</div>
  {{/unless}}
  {{#each (reverse limit_break) }}
    {{> "systems/ffxiv/templates/actor/parts/actor-card-limitbreak.hbs" this}}
  {{/each}}
  {{#each traits }}
    <div class="ability-container">
      {{> "systems/ffxiv/templates/actor/parts/actor-card-traits.hbs" this}}
      <div class="move-buttons">
        {{#unless @first}}
        <button type="button"
                class="move-up"
                data-item-id="{{_id}}"
                data-type="trait"
                aria-label="{{localize 'FFXIV.MoveUp'}}">
          <i class="fa-solid fa-chevron-up" aria-hidden="true"></i>
        </button>
      {{/unless}}
      {{#unless @last}}
      <button type="button"
              class="move-down"
              data-item-id="{{_id}}"
              data-type="trait"
              aria-label="{{localize 'FFXIV.MoveDown'}}">
        <i class="fa-solid fa-chevron-down" aria-hidden="true"></i>
      </button>
    {{/unless}}
  </div>
</div>
{{/each}}
</section>
{{/if}}
</div>
</div>
