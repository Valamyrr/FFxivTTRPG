<div class="fixed-part">
  <img class="profile-img character-img actor-avatar"
       src="{{ actor.img }}"
       {{#if actorEditMode }}
       data-edit="img"
       {{/if}}
       title="{{ actor.name }}"
       alt="avatar"  width="32" height="32" />
  <div class="stat-bars">
    <div class="resource flex-group-center compact-health-resource">
      <label for="system.health.value"
             class="resource-label health-resource-label">
        <span class="barrier-chip">
          <span class="barrier-chip-label">{{ localize "FFXIV.Health.barrier" }}</span>
          <input type="text"
                 inputmode="numeric"
                 class="barrier-input"
                 value="{{ system.barrier.value }}"
                 name="system.barrier.value" />
        </span>
      </label>
      <div class="resource-content flexrow flex-center flex-between">
        <div class="ffxiv-gauge health-gauge">
          <div class="gauge-label">{{ localize "FFXIV.Health.abbrv" }}</div>
          <div class="health-border gauge-track">
            <div class="health-bar gauge-fill"></div>
            <div class="barrier-overlay"></div>
            <div class="barrier-overflow"></div>
            <div class="gauge-values">
              <input type="text"
                     inputmode="numeric"
                     class="health-input"
                     value="{{ system.health.value }}"
                     name="system.health.value" />
              <span class="gauge-divider">/</span>
              <input type="number"
                     class="health-input"
                     min="0"
                     value="{{ system.health.max }}"
                     name="system.health.max" />
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="resource flex-group-center">
      <div class="resource-content flexrow flex-center flex-between">
        <div class="ffxiv-gauge mana-gauge">
          <div class="gauge-label">{{ localize "FFXIV.Mana.abbrv" }}</div>
          <div class="mana-bar gauge-track">
            <div class="mana-fill gauge-fill"></div>
            <div class="gauge-values">
              <span class="mana-value-current">{{ system.mana.value }}</span>
              <span class="gauge-divider">/</span>
              <span class="mana-value-max">{{ system.mana.max }}</span>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="sidebar-stat-summary">
      <div class="sidebar-stat-primary"
           aria-label="{{ localize 'FFXIV.Attributes.Primary' }}">
        <div class="sidebar-stat-cell roll-attribute"
             data-attribute="strength"
             role="button"
             tabindex="0"
             title="{{ localize 'FFXIV.Attributes.Strength.long' }}">
          <span class="sidebar-stat-label">{{ localize "FFXIV.Attributes.Strength.abbrv" }}</span>
          <span class="sidebar-stat-value">{{ add rollData.str 0 }}</span>
        </div>
        <div class="sidebar-stat-cell roll-attribute"
             data-attribute="dexterity"
             role="button"
             tabindex="0"
             title="{{ localize 'FFXIV.Attributes.Dexterity.long' }}">
          <span class="sidebar-stat-label">{{ localize "FFXIV.Attributes.Dexterity.abbrv" }}</span>
          <span class="sidebar-stat-value">{{ add rollData.dex 0 }}</span>
        </div>
        <div class="sidebar-stat-cell roll-attribute"
             data-attribute="vitality"
             role="button"
             tabindex="0"
             title="{{ localize 'FFXIV.Attributes.Vitality.long' }}">
          <span class="sidebar-stat-label">{{ localize "FFXIV.Attributes.Vitality.abbrv" }}</span>
          <span class="sidebar-stat-value">{{ add rollData.vit 0 }}</span>
        </div>
        <div class="sidebar-stat-cell roll-attribute"
             data-attribute="intelligence"
             role="button"
             tabindex="0"
             title="{{ localize 'FFXIV.Attributes.Intelligence.long' }}">
          <span class="sidebar-stat-label">{{ localize "FFXIV.Attributes.Intelligence.abbrv" }}</span>
          <span class="sidebar-stat-value">{{ add rollData.int 0 }}</span>
        </div>
        <div class="sidebar-stat-cell roll-attribute"
             data-attribute="mind"
             role="button"
             tabindex="0"
             title="{{ localize 'FFXIV.Attributes.Mind.long' }}">
          <span class="sidebar-stat-label">{{ localize "FFXIV.Attributes.Mind.abbrv" }}</span>
          <span class="sidebar-stat-value">{{ add rollData.mnd 0 }}</span>
        </div>
      </div>
      <div class="sidebar-stat-secondary"
           aria-label="{{ localize 'FFXIV.Attributes.Secondary' }}">
        <div class="sidebar-secondary-cell"
             title="{{ localize 'FFXIV.Attributes.Defense' }}">
          {{#if settings.attributesImgDefense }}
            <img src="{{ settings.attributesImgDefense }}"
                 alt="{{ localize 'FFXIV.Attributes.Defense' }}" width="32" height="32">
          {{/if}}
          <span class="sidebar-secondary-value">{{ add rollData.def 0 }}</span>
        </div>
        <div class="sidebar-secondary-cell"
             title="{{ localize 'FFXIV.Attributes.MagicDefense' }}">
          {{#if settings.attributesImgMagicDefense }}
            <img src="{{ settings.attributesImgMagicDefense }}"
                 alt="{{ localize 'FFXIV.Attributes.MagicDefense' }}" width="32" height="32">
          {{/if}}
          <span class="sidebar-secondary-value">{{ add rollData.mdef 0 }}</span>
        </div>
        <div class="sidebar-secondary-cell"
             title="{{ localize 'FFXIV.Attributes.Vigilance' }}">
          {{#if settings.attributesImgVigilance }}
            <img src="{{ settings.attributesImgVigilance }}"
                 alt="{{ localize 'FFXIV.Attributes.Vigilance' }}" width="32" height="32">
          {{/if}}
          <span class="sidebar-secondary-value">{{ add rollData.vigilance 0 }}</span>
        </div>
      </div>
    </div>
    {{#if jobResources.length}}
      <div class="job-resource-summary ability-limitations">
        {{#each jobResources as |resource|}}
          <div class="job-resource-row" title="{{resource.name}}">
            <div class="job-resource-label">
              <span>{{resource.name}}</span>
              <span class="job-resource-count">{{resource.count}}/{{resource.max}}</span>
            </div>
            <div class="job-resource-boxes">
              {{#repeat resource.max}}
                <div class="limitation-wrapper">
                  <input type="checkbox"
                         class="job_resource"
                         data-item-id="{{../id}}"
                         data-index="{{index}}"
                         {{#if (lookup ../status index)}}checked{{/if}}
                         {{#unless ../../owner}}disabled{{/unless}} />
                  <span class="checkmark"></span>
                </div>
              {{/repeat}}
            </div>
          </div>
        {{/each}}
      </div>
    {{/if}}
  </div>
</div>
