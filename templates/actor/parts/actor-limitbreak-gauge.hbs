{{#if limitBreakGauge.enabled}}
{{!-- Will probably move this to its own thing in the HUD later but for now it's glulded to character sheets. > --}}
  <section class="limit-break-gauge"
           data-limit-break-gauge
           style="--limit-break-segments: {{limitBreakGauge.max}};">
    <div class="limit-break-gauge-title">{{localize "FFXIV.ItemType.limit_break"}}</div>
    <div class="limit-break-gauge-row">
      {{#each limitBreakGauge.segments}}
        <button type="button"
                class="limit-break-segment limit-break-control {{#if filled}}filled{{/if}}"
                data-action="set"
                data-value="{{value}}"
                {{#unless ../isGM}}disabled{{/unless}}>
          <span class="limit-break-segment-fill"></span>
        </button>
      {{/each}}
    </div>
  </section>
{{/if}}