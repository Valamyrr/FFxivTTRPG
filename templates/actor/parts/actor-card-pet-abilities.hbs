<div class="ability-card" data-item-id="{{_id}}">
  <div class="ability-card-info">
    <div class="ability-icon-wrapper">
      <img src="{{img}}"
           alt="{{name}}"
           class="ability-icon"
           data-item-id="{{_id}}" width="32" height="32">
      <button type="button"
              class="ability-delete"
              data-item-id="{{_id}}"
              data-pet-id="{{parent._id}}"
              aria-label="{{localize 'FFXIV.Item.Delete'}}">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>
    <div class="ability-header">
      <div class="ability-name">{{name}}</div>
      <div class="ability-right">
        <div class="ability-tags">
          {{#each (actionTags type system.tags) as |tag| }}
            <span class="tag">{{localize tag}}</span>
          {{/each}}
          {{#if system.job_resources_max}}
            <div class="ability-limitations">
              {{#repeat system.job_resources_max}}
                <div class="limitation-wrapper">
                  <input type="checkbox"
                         class="job_resource"
                         data-index="{{index}}"
                         data-item-id="{{../_id}}"
                         {{#if (lookup ../system.job_resource_status index) }}
                         checked
                         {{/if}}>
                  <span class="checkmark"></span>
                </div>
              {{/repeat}}
            </div>
          {{/if}}
        </div>
      </div>
    </div>
  </div>
  <div class="ability-details">
    {{#if system.cost }}
      <div class="detail">
        <strong>{{localize "FFXIV.Abilities.Cost" }}:</strong> {{system.cost}}
      </div>
    {{/if}}
    {{#if system.target }}
      <div class="detail">
        <strong>{{ localize "FFXIV.Abilities.Target" }}:</strong> {{system.target}}
      </div>
    {{/if}}
    {{#if system.range }}
      <div class="detail">
        <strong>{{ localize "FFXIV.Abilities.Range" }}:</strong> {{system.range}}
      </div>
    {{/if}}
    {{#if system.check }}
      {{#if (not (eq system.check (localize "FFXIV.None"))) }}
        <div class="detail">
          <strong>{{ localize "FFXIV.Abilities.Check"}}:</strong>
          {{localize system.check}}
        </div>
      {{/if}}
    {{/if}}
    {{#if system.challenge }}
      <div class="detail">
        <strong>{{ localize "FFXIV.Abilities.Challenge" }}:</strong> {{system.challenge}}
      </div>
    {{/if}}
    {{#if system.combo }}
      {{> "systems/ffxiv/templates/item/parts/combo-chain.hbs" combo=system.combo current=name showLabel=true}}
    {{/if}}
    {{#if system.trigger }}
      <div class="detail">
        <strong>{{ localize "FFXIV.Abilities.Trigger" }}:</strong> {{system.trigger}}
      </div>
    {{/if}}
    {{#if system.condition }}
      <div class="detail">
        <strong>{{ localize "FFXIV.Abilities.Condition" }}:</strong> {{system.condition}}
      </div>
    {{/if}}
  </div>
  <div class="ability-effects">
    {{#if system.base_effect }}
      <div class="effect">
        <strong>{{ localize "FFXIV.Abilities.BaseEffect" }}:</strong> {{{enriched.base_effect}}}
      </div>
    {{/if}}
    {{#if system.direct_hit }}
      <div class="effect">
        <strong>{{ localize "FFXIV.Abilities.DirectHit" }}:</strong> {{{enriched.direct_hit}}}
      </div>
    {{/if}}
    {{#if system.limitations }}
      <div class="effect">
        <strong>{{ localize "FFXIV.Abilities.Limitations" }}:</strong> {{{enriched.limitations}}}
      </div>
    {{/if}}
    {{#if system.marker_area }}
      <div class="effect">
        <strong>{{ localize "FFXIV.Abilities.MarkerArea" }}:</strong> {{{enriched.marker_area}}}
      </div>
    {{/if}}
    {{#if system.origin }}
      <div class="effect">
        <strong>{{ localize "FFXIV.Abilities.Origin" }}:</strong> {{{enriched.origin}}}
      </div>
    {{/if}}
    {{#if system.marker_trigger }}
      <div class="effect">
        <strong>{{ localize "FFXIV.Abilities.MarkerTrigger" }}:</strong> {{{enriched.marker_trigger}}}
      </div>
    {{/if}}
    {{#if system.marker_effect }}
      <div class="effect">
        <strong>{{ localize "FFXIV.Abilities.MarkerEffect" }}:</strong> {{{enriched.marker_effect}}}
      </div>
    {{/if}}
  </div>
  {{#if system.description }}
    <div class="ability-description">
      <p>{{{enriched.description}}}</p>
    </div>
  {{/if}}
  <button type="button"
          class="pet-ability-roll-button"
          data-item-id="{{_id}}"
          data-pet-id="{{parent._id}}">{{ localize "FFXIV.CharacterSheet.Roll" }}</button>
</div>
