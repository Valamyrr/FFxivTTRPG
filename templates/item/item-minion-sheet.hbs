<div class="{{cssClass}} minion-mount-sheet">
  <header class="sheet-header">
    <img class="profile-img"
         src="{{item.img}}"
         data-edit="img"
         title="{{item.name}}"  alt="" width="32" height="32" />
    <div class="header-fields">
      <h1 class="charname">
        <input name="name" type="text" value="{{item.name}}" placeholder="Name" />
      </h1>
    </div>
    <button type="button"
            class="item-delete"
            aria-label="{{localize 'FFXIV.Item.Delete'}}">
      <i class="fa-solid fa-trash-can"></i>
    </button>
  </header>
  {{! Sheet Tab Navigation }}
  <nav class="sheet-tabs nav-sub-tabs" data-group="primary">
    <a class="sub-tab" data-tab="details">{{ localize "FFXIV.Item.Description" }} & {{ localize "FFXIV.Abilities.TraitsShort" }}
      <div class="chip"></div>
    </a>
    <a class="sub-tab" data-tab="attributes">{{ localize "FFXIV.Attributes.Attributes" }}
      <div class="chip"></div>
    </a>
  </nav>
  {{! Sheet Body }}
  <section class="sheet-body">
    {{! Details Tab }}
    <div class="tab details-tab" data-group="primary" data-tab="details">
      <div class="minion-details-card">
        <div class="minion-details-summary">
          <span class="minion-meta-pill">{{ localize system.minion_type }}</span>
          {{#if system.price.buy }}
            <span class="minion-meta-pill">{{ localize "FFXIV.Item.Buy" }}: {{system.price.buy}}
              {{#if system.price.denomination }}
              {{ localize system.price.denomination}}{{/if}}</span>
            {{/if}}
            {{#if system.price.sell }}
              <span class="minion-meta-pill">{{ localize "FFXIV.Item.Sell" }}: {{system.price.sell}}
                {{#if system.price.denomination }}
                {{ localize system.price.denomination}}{{/if}}</span>
              {{/if}}
              {{#if (hasItemQuality system) }}
                <span class="minion-meta-pill">{{ localize (itemQualityLabelKey system) }}: {{itemQualityDisplay system}}</span>
              {{/if}}
            </div>
            <div class="minion-details-section">
              <h3>{{ localize "FFXIV.Abilities.TraitsShort" }}</h3>
              <prose-mirror name="system.traits" value="{{source.traits}}" document-uuid="{{item.uuid}}" class="sized minion-details-editor"></prose-mirror>
            </div>
            <div class="minion-details-section">
              <h3>{{ localize "FFXIV.Item.Description" }}</h3>
              <prose-mirror name="system.description" value="{{source.description}}" document-uuid="{{item.uuid}}" class="sized minion-details-editor"></prose-mirror>
            </div>
          </div>
        </div>
        <div class="tab" data-group="primary" data-tab="attributes">
          <div class="resource flex-group-center">
            <label for="system.minion_type" class="resource-label">{{ localize "FFXIV.Item.MinionType" }}</label>
            <div class="resource-content flexrow flex-center flex-between">
              <select class="ffxiv-text-center" name="system.minion_type">
                {{#each this.config.minion_types as |t| }}
                  <option value="{{t}}" {{#if (eq t ../system.minion_type) }}selected {{/if}}>{{ localize t }}
                  </option>
                {{/each}}
              </select>
            </div>
          </div>
          <div class="resources grid grid-2col">
            <div class="resource flex-group-center consumable-price-resource">
              <label for="system.price.buy" class="resource-label">{{ localize "FFXIV.Item.Prices" }}</label>
              <div class="resource-content consumable-price-inline">
                <span class="consumable-price-key">{{ localize "FFXIV.Item.BuyShort" }}</span>
                <input class="consumable-price-input"
                       name="system.price.buy"
                       type="number"
                       value="{{system.price.buy}}" />
                <span class="consumable-price-divider">|</span>
                <span class="consumable-price-key">{{ localize "FFXIV.Item.SellShort" }}</span>
                <input class="consumable-price-input"
                       name="system.price.sell"
                       type="number"
                       value="{{system.price.sell}}" />
              </div>
            </div>
            <div class="resource flex-group-center">
              <label for="system.price.denomination" class="resource-label">{{ localize "FFXIV.Item.Denomination" }}</label>
              <div class="resource-content flexrow flex-center flex-between">
                <input name="system.price.denomination"
                       type="text"
                       value="{{system.price.denomination}}" />
              </div>
            </div>
            <div class="resource flex-group-center">
              <label for="system.shop_tier" class="resource-label">{{ localize "FFXIV.Item.ShopTier" }}</label>
              <div class="resource-content flexrow flex-center flex-between">
                <select class="ffxiv-text-center" name="system.shop_tier">
                  <option value="">{{ localize "FFXIV.None" }}</option>
                  {{#each this.config.shop_tiers as |tier| }}
                    <option value="{{tier.value}}"
                            {{#if (eq tier.value ../system.shop_tier) }}
                            selected
                            {{/if}}>{{ localize tier.label }}
                    </option>
                  {{/each}}
                </select>
              </div>
            </div>
            <div class="resource flex-group-center">
              <label for="system.rarity" class="resource-label">{{ localize "FFXIV.Item.Rarity" }}</label>
              <div class="resource-content flexrow flex-center flex-between">
                <select class="ffxiv-text-center" name="system.rarity">
                  <option value="">{{ localize "FFXIV.None" }}</option>
                  {{#each this.config.rarities as |rarity| }}
                    <option value="{{rarity.value}}"
                            {{#if (eq rarity.value ../system.rarity) }}
                            selected
                            {{/if}}>{{ localize rarity.label }}
                    </option>
                  {{/each}}
                </select>
              </div>
            </div>
            {{#if (eq system.shop_tier "custom") }}
              <div class="resource flex-group-center">
                <label for="system.shop_tier_custom" class="resource-label">{{ localize "FFXIV.ShopTier.CustomLabel" }}</label>
                <div class="resource-content flexrow flex-center flex-between">
                  <input name="system.shop_tier_custom"
                         type="text"
                         value="{{system.shop_tier_custom}}" />
                </div>
              </div>
            {{/if}}
          </div>
        </div>
      </section>
    </div>
