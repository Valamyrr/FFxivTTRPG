<hr>
<div class="{{#if abilityPanel}}ability-sheet-panel{{else}}status-effects-editor{{/if}} summon-actors-editor summon-actors-dropzone">
  {{#if abilityPanel}}
    <header class="ability-panel-header">
      <h2>{{ localize "FFXIV.Abilities.Summons" }}</h2>
    </header>
  {{else}}
    <div class="status-effects-header">
      <label class="resource-label">{{ localize "FFXIV.Abilities.Summons" }}</label>
    </div>
  {{/if}}
  <ol class="job-ability-list">
    {{#unless system.summon_actors.length}}
      <li class="job-ability-empty">{{ localize "FFXIV.Abilities.DropSummons" }}</li>
    {{/unless}}
    {{#each system.summon_actors as |summon index| }}
      <li class="job-ability-row summon-actor-edit" data-index="{{index}}">
        <span class="job-ability-name">{{summon.name}}</span>
        <span class="job-ability-type">{{summon.typeLabel}}</span>
        <button type="button"
                class="move-summon-actor-up"
                data-index="{{index}}"
                aria-label="Move Up"
                {{#if @first}}disabled{{/if}}>▲</button>
        <button type="button"
                class="move-summon-actor-down"
                data-index="{{index}}"
                aria-label="Move Down"
                {{#if @last}}disabled{{/if}}>▼</button>
        <button type="button"
                class="remove-summon-actor"
                data-index="{{index}}"
                aria-label="{{localize 'FFXIV.Item.Delete'}}">
          <i class="fa-solid fa-xmark"></i>
        </button>
      </li>
    {{/each}}
  </ol>
</div>
