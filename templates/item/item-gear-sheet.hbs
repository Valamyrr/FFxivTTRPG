<div class="{{cssClass}} item-modern-sheet">
  <header class="sheet-header">
    <img class="profile-img"
         src="{{item.img}}"
         data-edit="img"
         title="{{item.name}}"  alt="" width="32" height="32" />
    <div class="header-fields">
      <h1 class="charname">
        <input name="name" type="text" value="{{item.name}}" placeholder="Name" />
      </h1>
    </div>
    <button type="button"
            class="item-delete"
            aria-label="{{localize 'FFXIV.Item.Delete'}}">
      <i class="fa-solid fa-trash-can"></i>
    </button>
  </header>
  {{! Sheet Body }}
  <section class="sheet-body">
    <div class="resources grid grid-3col">
      {{#if item.parent }}
        <div class="resource flex-group-center">
          <label class="resource-label">{{ localize "FFXIV.CharacterSheet.Gear" }}</label>
          <div class="resource-content flexrow flex-center flex-between">
            <button type="button" class="item-qty-btn gear-equip">
              <i class="fa-solid fa-user"></i>
              {{#if system.equipped }}
                {{ localize "FFXIV.CharacterSheet.Unequip" }}
              {{else}}
                {{ localize "FFXIV.CharacterSheet.Equip" }}
              {{/if}}
            </button>
          </div>
        </div>
      {{/if}}
      <div class="resource flex-group-center">
        <label for="system.category" class="resource-label">{{ localize "FFXIV.GearCategories.Category" }}</label>
        <div class="resource-content flexrow flex-center flex-between">
          <select class="ffxiv-text-center" name="system.category">
            {{#each this.config.gear_subcategories as |a| }}
              <option value="{{a.label}}"
                      {{#if (eq a.label ../item.system.category) }}
                      selected
                      {{/if }}>{{ localize a.label }}
              </option>
            {{/each}}
          </select>
        </div>
      </div>
      <div class="resource flex-group-center">
        <label for="system.level" class="resource-label">{{ localize "FFXIV.Level" }}</label>
        <div class="resource-content flexrow flex-center flex-between">
          <input type="text" name="system.level" value="{{ system.level }}">
        </div>
      </div>
      <div class="resource flex-group-center">
        <label for="system.shop_tier" class="resource-label">{{ localize "FFXIV.Item.ShopTier" }}</label>
        <div class="resource-content flexrow flex-center flex-between">
          <select class="ffxiv-text-center" name="system.shop_tier">
            <option value="">{{ localize "FFXIV.None" }}</option>
            {{#each this.config.shop_tiers as |tier| }}
              <option value="{{tier.value}}"
                      {{#if (eq tier.value ../system.shop_tier) }}
                      selected
                      {{/if }}>{{ localize tier.label }}
              </option>
            {{/each}}
          </select>
        </div>
      </div>
      <div class="resource flex-group-center">
        <label for="system.rarity" class="resource-label">{{ localize "FFXIV.Item.Rarity" }}</label>
        <div class="resource-content flexrow flex-center flex-between">
          <select class="ffxiv-text-center" name="system.rarity">
            <option value="">{{ localize "FFXIV.None" }}</option>
            {{#each this.config.rarities as |rarity| }}
              <option value="{{rarity.value}}"
                      {{#if (eq rarity.value ../system.rarity) }}
                      selected
                      {{/if }}>{{ localize rarity.label }}
              </option>
            {{/each}}
          </select>
        </div>
      </div>
      {{#if (eq system.shop_tier "custom") }}
        <div class="resource flex-group-center">
          <label for="system.shop_tier_custom" class="resource-label">{{ localize "FFXIV.ShopTier.CustomLabel" }}</label>
          <div class="resource-content flexrow flex-center flex-between">
            <input name="system.shop_tier_custom"
                   type="text"
                   value="{{system.shop_tier_custom}}" />
          </div>
        </div>
      {{/if}}
    </div>
    <div class="resources grid grid-2col">
      <div class="resource flex-group-center consumable-price-resource">
        <label for="system.price.buy" class="resource-label">{{ localize "FFXIV.Item.Prices" }}</label>
        <div class="resource-content consumable-price-inline">
          <span class="consumable-price-key">{{ localize "FFXIV.Item.BuyShort" }}</span>
          <input class="consumable-price-input"
                 name="system.price.buy"
                 type="number"
                 value="{{item.system.price.buy}}" />
          <span class="consumable-price-divider">|</span>
          <span class="consumable-price-key">{{ localize "FFXIV.Item.SellShort" }}</span>
          <input class="consumable-price-input"
                 name="system.price.sell"
                 type="number"
                 value="{{item.system.price.sell}}" />
        </div>
      </div>
      <div class="resource flex-group-center">
        <label for="system.price.denomination" class="resource-label">{{ localize "FFXIV.Item.Denomination" }}</label>
        <div class="resource-content flexrow flex-center flex-between">
          <input name="system.price.denomination"
                 type="text"
                 value="{{localize item.system.price.denomination}}" />
        </div>
      </div>
      <div class="resource flex-group-center">
        <label for="system.weight" class="resource-label">{{ localize "FFXIV.Item.Weight" }}</label>
        <div class="resource-content flexrow flex-center flex-between">
          <input name="system.weight" type="text" value="{{item.system.weight}}" />
        </div>
      </div>
    </div>
    <div class="tags-container">
      <label for="system.tags" class="resource-label">{{ localize "FFXIV.Item.JobRequirement" }}</label>
      <button type="button" class="add-class">+</button>
      <ul class="tag-list">
        {{#each system.classes as |class index| }}
          <li>
            <select class="ffxiv-text-center select-classes">
              <option value="" {{#if (eq "" class) }}selected {{/if }}>{{ localize "FFXIV.None" }}
              </option>
              {{#each ../settings.jobsAbbrv as |c| }}
                <option value="{{c}}" {{#if (eq c class) }}selected {{/if }}>{{ localize c }}
                </option>
              {{/each}}
            </select>
            <button type="button" class="remove-class" data-index="{{index}}">x</button>
          </li>
        {{/each}}
      </ul>
    </div>
    <div class="tags-container">
      <label for="system.modifiers" class="resource-label">{{ localize "FFXIV.Item.Modifiers" }}</label>
      <button type="button" class="add-modifier">+</button>
      <ul class="tag-list">
        {{#each system.modifiers as |modifier index| }}
          <li>
            <select class="ffxiv-text-center modifier-name"
                    data-index="{{index}}">
              {{#each ../config.attributes as |m| }}
                <option value="{{m.label}}"
                        {{#if (eq m.label modifier.[0]) }}
                        selected
                        {{/if }}>{{ localize m.label }}
                </option>
              {{/each}}
              {{#each ../config.characteristics as |m| }}
                <option value="{{m.label}}"
                        {{#if (eq m.label modifier.[0]) }}
                        selected
                        {{/if }}>{{ localize m.label }}
                </option>
              {{/each}}
            </select>
            <input type="text"
                   class="modifier-value"
                   value="{{modifier.[1]}}"
                   data-index="{{index}}">
            <button type="button" class="remove-modifier" data-index="{{index}}">x</button>
          </li>
        {{/each}}
      </ul>
    </div>
    <prose-mirror name="system.description" value="{{source.description}}" document-uuid="{{item.uuid}}" class="sized"></prose-mirror>
  </section>
</div>
