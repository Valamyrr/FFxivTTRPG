<div class="{{cssClass}}">
  <header class="sheet-header">
    <img class="profile-img"
         src="{{item.img}}"
         data-edit="img"
         title="{{item.name}}"
         alt="{{item.name}}"
         width="96"
         height="96" />
    <div class="header-fields">
      <h1 class="charname">
        <input name="name" type="text" value="{{item.name}}" placeholder="Name" />
      </h1>
    </div>
  </header>
  {{! Sheet Tab Navigation }}
  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="description">{{ localize "FFXIV.Item.Description" }}</a>
    <a class="item" data-tab="attributes">{{ localize "FFXIV.Attributes.Attributes" }}</a>
  </nav>
  {{! Sheet Body }}
  <section class="sheet-body">
    {{! Description Tab }}
    <div class="tab" data-group="primary" data-tab="description">
      {{! Editors must receive enriched text data from getData to properly handle rolls }}
      <prose-mirror name="system.description" value="{{source.description}}" document-uuid="{{item.uuid}}" class="sized"></prose-mirror>
    </div>
    {{! Attributes Tab }}
    <div class="tab attributes" data-group="primary" data-tab="attributes">
      {{! As you add new fields, add them in here! }}
    </div>
  </section>
</div>
