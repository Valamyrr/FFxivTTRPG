<div class="{{cssClass}} limited-display">
  <div class="item-card">
    <div class="item-card-info">
      <img src="{{item.img}}" alt="{{item.name}}" class="item-dialog-icon" width="48" height="48">
      <div class="item-dialog-header">
        <div class="item-dialog-name {{rarityTextClass item.system.rarity}}">{{item.name}}</div>
        <div class="item-dialog-right">
          <div class="item-dialog-tags">
            <span class="tag">{{ localize item.system.category }}</span>
          </div>
        </div>
      </div>
      <div class="item-dialog-details">
        {{#each system.classes as |class| }}
          <span>{{localize class}}{{#unless @last}}  {{/unless}}</span>
        {{/each}}
        <div>LV {{ system.level }}</div>
        <br>
        {{#if (hasItemQuality item.system) }}
          <div class="detail">
            <strong>{{localize (itemQualityLabelKey item.system)}}:</strong> {{itemQualityDisplay item.system}}
          </div>
        {{/if}}
        {{#if (not (eq item.system.price.buy 0)) }}
          <div class="detail">
            <strong>{{ localize "FFXIV.Item.Buy" }}:</strong> {{item.system.price.buy}}
            {{#if item.system.price.denomination }}
              {{localize item.system.price.denomination}}{{/if}}
            </div>
          {{/if}}
          {{#if (not (eq item.system.price.sell 0)) }}
            <div class="detail">
              <strong>{{ localize "FFXIV.Item.Sell" }}:</strong> {{item.system.price.sell}}
              {{#if item.system.price.denomination }}
                {{localize item.system.price.denomination}}{{/if}}
              </div>
            {{/if}}
            {{#if item.system.weight }}
              <div class="detail">
                <strong>{{ localize "FFXIV.Item.Weight" }}:</strong> {{item.system.weight}}
              </div>
            {{/if}}
          </div>
          <div class="item-dialog-effects">
            <table>
              {{#each system.modifiers as |modifier| }}
                <tr>
                  <td>
                    {{localize modifier.[0]}}
                    {{#if (superior modifier.[1] 0) }}
                      +{{/if}}{{modifier.[1]}}
                  </td>
                </tr>
              {{/each}}
            </table>
      </div>
      {{#if system.description }}
        <div class="item-dialog-description">
          {{{enrichedDescription}}}
          {{^enrichedDescription}}{{item.system.description}}{{/enrichedDescription}}
        </div>
      {{/if}}
      <div class="quantity-form">
        {{#if (not system.equipped) }}
          <div class="detail">
            <strong>{{ localize "FFXIV.CharacterSheet.Equip" }} :</strong>
          </div>
          <button type="button"
                  class="item-qty-btn gear-equip"
                  aria-label="{{localize 'FFXIV.CharacterSheet.Equip'}}">
            <i class="fa-solid fa-user"></i>
          </button>
        {{else}}
          <div class="detail">
            <strong>{{ localize "FFXIV.CharacterSheet.Unequip" }} :</strong>
          </div>
          <button type="button"
                  class="item-qty-btn gear-equip"
                  aria-label="{{localize 'FFXIV.CharacterSheet.Unequip'}}">
            <i class="fa-solid fa-user"></i>
          </button>
        {{/if}}
        <br>
        <div class="detail">
          <strong>{{ localize "FFXIV.Item.Delete" }} :</strong>
        </div>
        <button type="button"
                class="item-qty-btn delete"
                aria-label="{{localize 'FFXIV.Item.Delete'}}">
          <i class="fa-solid fa-trash-can"></i>
        </button>
      </div>
      <button type="button" class="item-roll-button">{{ localize "FFXIV.CharacterSheet.Show" }}</button>
    </div>
  </div>
</div>
