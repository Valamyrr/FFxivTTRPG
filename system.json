{
  "id": "ffxiv",
  "title": "Final Fantasy XIV TTRPG",
  "description": "An unofficial port of the Final Fantasy XIV TTRPG system for FoundryVTT",
  "compatibility": {
    "minimum": "14",
    "verified": "14.364"
  },
  "version": "4.9.9-dev",
  "authors": [
    {
      "name": "Valamyrr",
      "url": "https://github.com/Valamyrr/",
      "discord": "valamyrr"
    },
    {
      "name": "AxeBane",
      "url": "https://github.com/AxeBane/",
      "discord": "axebane"
    }
  ],
  "media": [
    {
      "type": "setup",
      "url": "systems/ffxiv/assets/header-logo.webp",
      "thumbnail": "systems/ffxiv/assets/header-logo.webp"
    }
  ],
  "esmodules": ["module/ffxiv.mjs"],
  "documentTypes": {
    "Actor": {
      "character": {
        "htmlFields": ["biography", "profile_trait.effect"]
      },
      "npc": {
        "htmlFields": ["biography"]
      },
      "pet": {}
    },
    "Item": {
      "ability": {
        "htmlFields": ["description"]
      },
      "consumable": {
        "htmlFields": ["description"]
      },
      "currency": {
        "htmlFields": ["description"]
      },
      "limit_break": {
        "htmlFields": ["description"]
      },
      "primary_ability": {
        "htmlFields": ["description"]
      },
      "secondary_ability": {
        "htmlFields": ["description"]
      },
      "instant_ability": {
        "htmlFields": ["description"]
      },
      "trait": {
        "htmlFields": ["description"]
      },
      "title": {
        "htmlFields": ["description"]
      },
      "gear": {
        "htmlFields": ["description"]
      },
      "minion": {
        "htmlFields": ["description", "traits"]
      },
      "augment": {
        "htmlFields": ["description"]
      },
      "job": {
        "htmlFields": ["description"]
      }
    }
  },
  "primaryTokenAttribute": "resources.health",
  "styles": ["css/ffxiv.css"],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json"
    },
    {
      "lang": "fr",
      "name": "Français (French)",
      "path": "lang/fr.json"
    }
  ],
  "url": "https://github.com/Valamyrr/FFxivTTRPG",
  "manifest": "https://github.com/Valamyrr/FFxivTTRPG/releases/download/v4.9.9-dev/system.json",
  "download": "https://github.com/Valamyrr/FFxivTTRPG/releases/download/v4.9.9-dev/system.zip",
  "license": "LICENSE.txt",
  "socket": true
}
